# Ignore everything by default
*

# Include root config and metadata files
!/.gitignore
!/build.gradle.kts
!/settings.gradle.kts
!/gradle.properties
!/REQUIREMENTS.md
!/README.md
!/LICENSE
!/CONTRIBUTORS.md
!/CODE_OF_CONDUCT.md
!/SECURITY.md

# Project folders
!/.agent/
!/.agent/**
!/backend/
!/backend/**
!/frontend/
!/frontend/**

# Build artifacts and caches within modules
**/build/
**/.gradle/
**/.kotlin/
**/.DS_Store/
**/node_modules/
**/.output/
**/.vinxi/
**/.nitro/
**/bin/
**/*.class
**/*.jar
**/*.lock
**/*.log
**/*.log.zip
**/*.log.gz
**/*.db
**/*.tmp
**/*.bkp
**/*.bak

# Gradle 
!**/gradle/
!**/gradle/**

